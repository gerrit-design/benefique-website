    { "source": "/go/waterfall", "destination": "/blog/ai-cash-flow-waterfall-explained?utm_source=linkedin&utm_medium=social&utm_campaign=waterfall", "statusCode": 302 },
    { "source": "/go/financial-model", "destination": "/blog/concierge-medicine-financial-model?utm_source=linkedin&utm_medium=social&utm_campaign=financial-model", "statusCode": 302 },
    { "source": "/go/three-views", "destination": "/blog/three-views-one-business?utm_source=linkedin&utm_medium=social&utm_campaign=three-views", "statusCode": 302 },
    { "source": "/go/cost-center", "destination": "/blog/accountant-cost-center-roi-center?utm_source=linkedin&utm_medium=social&utm_campaign=cost-center", "statusCode": 302 },
    { "source": "/go/fixer-upper", "destination": "/blog/fixer-upper-or-walk-in-ready?utm_source=linkedin&utm_medium=social&utm_campaign=fixer-upper", "statusCode": 302 },
    { "source": "/go/breakeven", "destination": "/blog/fixed-cost-breakeven-volume-problem?utm_source=linkedin&utm_medium=social&utm_campaign=breakeven", "statusCode": 302 },
    { "source": "/go/per-unit", "destination": "/blog/per-unit-pnl-multi-location-cost-analysis?utm_source=linkedin&utm_medium=social&utm_campaign=per-unit", "statusCode": 302 }
